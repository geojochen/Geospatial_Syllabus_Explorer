<!DOCTYPE html>
<html>
<head>
    <title>Geospatial Syllabus Explorer</title>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    
    <style>
        /* --- RESET & LAYOUT --- */
        * { box-sizing: border-box; }
        html, body { height: 100%; width: 100%; margin: 0; padding: 0; overflow: hidden; font-family: 'Segoe UI', Roboto, Helvetica, Arial, sans-serif; }
        body { display: flex; flex-direction: row; }
        
        /* --- SIDEBAR --- */
        #sidebar {
            width: 450px; /* Slightly wider to accommodate more filters */
            min-width: 450px;
            height: 100vh;
            background: #fff;
            display: flex;
            flex-direction: column;
            border-right: 1px solid #ccc;
            z-index: 2000;
            box-shadow: 4px 0 15px rgba(0,0,0,0.1);
        }

        #sidebar-header { padding: 20px; background: #f8f9fa; border-bottom: 1px solid #e9ecef; }
        h2 { margin: 0 0 10px 0; font-size: 22px; color: #2c3e50; display: flex; align-items: center; gap: 10px; }
        
        /* --- STATUS PANEL --- */
        #status-panel {
            font-size: 11px;
            padding: 8px 12px;
            background: #e3f2fd;
            color: #0d47a1;
            border: 1px solid #90caf9;
            border-radius: 4px;
            margin-bottom: 15px;
            font-family: monospace;
            display: flex; justify-content: space-between; align-items: center;
        }
        #status-panel.error { background: #ffebee; color: #c62828; border-color: #ef9a9a; }
        #status-panel.success { background: #e8f5e9; color: #2e7d32; border-color: #a5d6a7; }

        /* --- FILTERS --- */
        .filter-section { margin-top: 10px; }
        .filter-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 8px; }
        
        /* Search Box */
        #search-box { width: 100%; padding: 10px; border: 1px solid #ced4da; border-radius: 4px; font-size: 14px; margin-bottom: 8px; }
        
        /* Select Inputs */
        select { width: 100%; padding: 8px; border: 1px solid #ced4da; border-radius: 4px; font-size: 12px; background: white; color: #444; }
        select:focus { border-color: #3498db; outline: none; }

        /* Highlight specific filters */
        #level-filter { border-left: 3px solid #e67e22; }
        #domain-filter { border-left: 3px solid #27ae60; }

        /* --- RESULTS AREA --- */
        #results-area { flex-grow: 1; overflow-y: auto; padding: 15px; background: #f4f6f8; }

        /* --- COURSE CARD --- */
        .card {
            background: white;
            border: 1px solid #e1e4e8;
            border-radius: 8px;
            margin-bottom: 12px;
            transition: all 0.2s;
            overflow: hidden;
            position: relative;
        }
        .card:hover { border-color: #3498db; box-shadow: 0 4px 8px rgba(0,0,0,0.08); transform: translateY(-1px); }
        .card.active { border-color: #3498db; box-shadow: 0 0 0 2px rgba(52, 152, 219, 0.2); }
        
        .card-header { padding: 15px; cursor: pointer; display: flex; justify-content: space-between; align-items: flex-start; }
        
        .card-title-row { flex-grow: 1; }
        .card h3 { margin: 0; font-size: 16px; color: #2c3e50; font-weight: 700; line-height: 1.3; }
        .card h3 .code { color: #3498db; margin-right: 6px; }
        .card p { margin: 4px 0 0; font-size: 13px; color: #666; line-height: 1.4; }
        
        .uni-badge { 
            display: inline-block; font-size: 10px; font-weight: 700; 
            color: #555; background: #eee; padding: 2px 6px; 
            border-radius: 4px; margin-top: 6px; text-transform: uppercase; 
        }

        /* --- TAGS & BADGES --- */
        .tags-row { display: flex; flex-wrap: wrap; gap: 5px; margin-top: 8px; }
        
        .badge { padding: 2px 6px; border-radius: 3px; font-size: 10px; font-weight: 600; border: 1px solid transparent; }
        
        /* Level Badges */
        .badge-level { background: #fff3e0; color: #e67e22; border-color: #ffe0b2; }
        /* Assessment Badges */
        .badge-assess { background: #e3f2fd; color: #1976d2; border-color: #bbdefb; }
        /* Domain Badges */
        .badge-domain { background: #e8f5e9; color: #2e7d32; border-color: #c8e6c9; }
        /* Tech Badges */
        .badge-tech { background: #f3e5f5; color: #7b1fa2; border-color: #e1bee7; }

        /* --- DETAILS SECTION --- */
        .card-details { display: none; padding: 0 15px 15px 15px; background: #fafbfc; border-top: 1px solid #eee; font-size: 13px; color: #444; }
        .card.active .card-details { display: block; }
        
        .detail-block { margin-top: 12px; }
        .detail-label { font-weight: 700; color: #333; font-size: 11px; text-transform: uppercase; display: block; margin-bottom: 4px; }
        .detail-text { color: #555; line-height: 1.5; }

        /* PDF Button */
        .pdf-btn {
            display: inline-flex; align-items: center; gap: 6px;
            background: #e74c3c; color: white; padding: 8px 12px; border-radius: 4px;
            text-decoration: none; font-size: 12px; font-weight: bold; margin-top: 15px;
            transition: background 0.2s;
        }
        .pdf-btn:hover { background: #c0392b; }

        /* --- MAP --- */
        #map { flex-grow: 1; height: 100vh; background-color: #e5e5e5; }
        
        /* --- SCHEDULE TABLE --- */
        .sched-table { width: 100%; border-collapse: collapse; margin-top: 5px; font-size: 12px; }
        .sched-table td { padding: 6px 4px; border-bottom: 1px solid #eee; vertical-align: top; }
        .sched-week { width: 60px; font-weight: bold; color: #95a5a6; font-size: 11px; }

        /* --- LOADING SPINNER --- */
        .spinner { display: inline-block; width: 12px; height: 12px; border: 2px solid rgba(0,0,0,0.1); border-left-color: #3498db; border-radius: 50%; animation: spin 1s linear infinite; margin-right: 5px; }
        @keyframes spin { 0% { transform: rotate(0deg); } 100% { transform: rotate(360deg); } }
    </style>
</head>
<body>

    <nav style="background: #2c3e50; color: white; padding: 10px 20px; display: flex; justify-content: space-between; align-items: center; border-bottom: 1px solid #ddd;">
    <div style="font-weight: bold; font-size: 1.1rem;"><a href="index.html" style="color: white; text-decoration: none;"><i class="fa-solid fa-arrow-left"></i> Back to Home</a></div>
    <div style="font-size: 0.9rem;">Geospatial Syllabus Explorer</div>
    </nav>
	
	<div id="sidebar">
        <div id="sidebar-header">
            <h2><i class="fa-solid fa-layer-group"></i> Syllabus Explorer</h2>
            
            <div id="status-panel">
                <span><div class="spinner"></div> Connecting to Database...</span>
            </div>

            <input type="text" id="search-box" placeholder="Search titles, skills, software (e.g. 'Lidar', 'Python')...">
            
            <div class="filter-section">
                <div class="filter-grid">
                    <select id="level-filter"><option value="all">Any Level (Undergrad/Grad)</option></select>
                    <select id="domain-filter"><option value="all">Any Domain (Urban, Env...)</option></select>
                    
                    <select id="assess-filter"><option value="all">Any Assessment Type</option></select>
                    <select id="software-filter"><option value="all">Filter by Software</option></select>
                    
                    <select id="uni-filter"><option value="all">All Universities</option></select>
                    <select id="format-filter"><option value="all">Any Format (Online/In-Person)</option></select>
                </div>
            </div>
            
            <div style="margin-top: 10px; font-size: 12px; color: #7f8c8d; display: flex; justify-content: space-between;">
                <span>Showing <b id="course-count">0</b> courses</span>
                <a href="#" onclick="resetFilters()" style="color: #3498db; text-decoration: none;">Reset Filters</a>
            </div>
        </div>

        <div id="results-area"></div>
    </div>

    <div id="map"></div>

    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
    <script src="https://unpkg.com/@supabase/supabase-js@2"></script>

    <script>
        // --- CONFIGURATION ---
        // REPLACE WITH YOUR PROJECT URL
        const SUPABASE_URL = 'https://ygzxhhmckfyeywdfrwcp.supabase.co'; 
        // REPLACE WITH YOUR ANON KEY
        const SUPABASE_KEY = 'eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6InlnenhoaG1ja2Z5ZXl3ZGZyd2NwIiwicm9sZSI6ImFub24iLCJpYXQiOjE3Njg0Nzc2MTAsImV4cCI6MjA4NDA1MzYxMH0.JrSW1-DyrduhK1_iAC-HgcwnxeDpzn98AVoriG0bTXw';
        const GITHUB_PDF_BASE_URL = 'https://geojochen.github.io/UCGISsyllabusDB/pdfs/';

        // --- GLOBAL STATE ---
        let globalData = [];
        let map, markers;

        // --- DOM ELEMENTS ---
        const statusEl = document.getElementById('status-panel');
        const countEl = document.getElementById('course-count');
        const resultsEl = document.getElementById('results-area');

        // --- INIT MAP ---
        function initMap() {
            map = L.map('map').setView([39.8, -98.5], 4);
            L.tileLayer('https://{s}.basemaps.cartocdn.com/rastertiles/voyager/{z}/{x}/{y}{r}.png', {
                attribution: '&copy; <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a> contributors &copy; <a href="https://carto.com/attributions">CARTO</a>'
            }).addTo(map);
            markers = L.layerGroup().addTo(map);
        }

        // --- LOGGING HELPER ---
        function log(msg, type='info') {
            statusEl.innerHTML = `<span>${type === 'loading' ? '<div class="spinner"></div>' : ''} ${msg}</span>`;
            statusEl.className = type === 'loading' ? '' : type;
        }

        // --- MAIN LOAD FUNCTION ---
        async function loadData() {
            initMap();
            log("Fetching syllabus data...", "loading");

            try {
                if (!window.supabase) throw new Error("Supabase library not loaded.");
                const supabase = window.supabase.createClient(SUPABASE_URL, SUPABASE_KEY);
                
                // Fetch from the View
                const { data, error } = await supabase.from('syllabus_map_view').select('*');

                if (error) throw error;
                if (!data || data.length === 0) throw new Error("Database connected but returned 0 rows.");

                // Sort alphabetically by University
                globalData = data.sort((a, b) => (a.university_name || "").localeCompare(b.university_name || ""));
                
                log(`Ready. Loaded ${data.length} courses.`, "success");
                
                populateFilters(globalData);
                render(globalData);

            } catch (err) {
                console.error(err);
                log(`Error: ${err.message}`, "error");
            }
        }

        // --- POPULATE DROPDOWNS ---
        // --- POPULATE DROPDOWNS (With Counts!) ---
        function populateFilters(data) {
            // Helper: Count unique values
            const getCounts = (key, isArray=false) => {
                const counts = {};
                data.forEach(d => {
                    const val = d[key];
                    if (!val) return; // Skip nulls

                    if (isArray && Array.isArray(val)) {
                        // Handle arrays (e.g. Software: ["ArcGIS", "Python"])
                        val.forEach(v => {
                            if(v) counts[v] = (counts[v] || 0) + 1;
                        });
                    } else if (!isArray) {
                        // Handle single strings (e.g. Level: "Graduate")
                        counts[val] = (counts[val] || 0) + 1;
                    }
                });
                return counts;
            };

            // Helper: Add options to <select>
            const addOpts = (id, counts) => {
                const sel = document.getElementById(id);
                if(!sel) return;

                // Keep the first "All" option, clear the rest
                sel.innerHTML = sel.firstElementChild.outerHTML;

                // Sort alphabetically and create options
                Object.keys(counts).sort().forEach(k => {
                    const opt = document.createElement('option');
                    opt.value = k;
                    opt.innerText = `${k} (${counts[k]})`; // <--- COUNTS RESTORED
                    sel.appendChild(opt);
                });
            };

            // 1. Level
            addOpts('level-filter', getCounts('course_level'));
            // 2. Domain (Array)
            addOpts('domain-filter', getCounts('application_domains', true));
            // 3. Assessment
            addOpts('assess-filter', getCounts('primary_assessment'));
            // 4. Software (Array)
            addOpts('software-filter', getCounts('required_software', true));
            // 5. University
            addOpts('uni-filter', getCounts('university_name'));
            // 6. Format
            addOpts('format-filter', getCounts('delivery_format'));
        }

        // --- FILTER LOGIC ---
        function applyFilters() {
            const search = document.getElementById('search-box').value.toLowerCase();
            const fLevel = document.getElementById('level-filter').value;
            const fDomain = document.getElementById('domain-filter').value;
            const fAssess = document.getElementById('assess-filter').value;
            const fSoft = document.getElementById('software-filter').value;
            const fUni = document.getElementById('uni-filter').value;
            const fFmt = document.getElementById('format-filter').value;

            const filtered = globalData.filter(item => {
                // Search Text Blob
                const blob = [
                    item.title, 
                    item.course_code, 
                    item.description, 
                    (item.keywords||[]).join(" "),
                    (item.tech_skills||[]).join(" ")
                ].join(" ").toLowerCase();

                const matchSearch = !search || blob.includes(search);
                const matchLevel = fLevel === 'all' || item.course_level === fLevel;
                const matchDomain = fDomain === 'all' || (item.application_domains || []).includes(fDomain);
                const matchAssess = fAssess === 'all' || item.primary_assessment === fAssess;
                const matchSoft = fSoft === 'all' || (item.required_software || []).includes(fSoft);
                const matchUni = fUni === 'all' || item.university_name === fUni;
                const matchFmt = fFmt === 'all' || item.delivery_format === fFmt;

                return matchSearch && matchLevel && matchDomain && matchAssess && matchSoft && matchUni && matchFmt;
            });

            render(filtered);
        }

        // --- RENDER CARDS ---
        function render(data) {
            countEl.innerText = data.length;
            resultsEl.innerHTML = '';
            markers.clearLayers();
            
            // Collect bounds
            const bounds = L.latLngBounds();

            data.forEach(d => {
                // 1. Add Map Marker
                if (d.lat && d.lon) {
                    const m = L.marker([d.lat, d.lon])
                        .bindPopup(`<b>${d.course_code}</b><br>${d.university_name}`);
                    m.addTo(markers);
                    bounds.extend([d.lat, d.lon]);
                }

                // 2. Build Card HTML
                const card = document.createElement('div');
                card.className = 'card';
                
                // Badges
                let badgesHtml = '';
                if (d.course_level) badgesHtml += `<span class="badge badge-level">${d.course_level}</span>`;
                if (d.primary_assessment) badgesHtml += `<span class="badge badge-assess">${d.primary_assessment}</span>`;
                (d.application_domains || []).slice(0,2).forEach(dom => 
                    badgesHtml += `<span class="badge badge-domain">${dom}</span>`
                );

                // Tech Skills
                let skillsHtml = '';
                (d.tech_skills || []).forEach(s => skillsHtml += `<span class="badge badge-tech">${s}</span>`);

                // Prerequisites
                const prereqText = d.prerequisites && d.prerequisites !== 'None listed' 
                    ? `<div class="detail-block"><span class="detail-label">Prerequisites</span><span class="detail-text">${d.prerequisites}</span></div>` 
                    : '';

                // PDF Link
                const pdfLink = d.pdf_filename 
                    ? `<a href="${GITHUB_PDF_BASE_URL}${d.pdf_filename}" target="_blank" class="pdf-btn"><i class="fa-regular fa-file-pdf"></i> View Syllabus PDF</a>`
                    : '';

                card.innerHTML = `
                    <div class="card-header" onclick="toggleCard(this, ${d.lat}, ${d.lon})">
                        <div class="card-title-row">
                            <h3><span class="code">${d.course_code}</span> ${d.title}</h3>
                            <span class="uni-badge">${d.university_name}</span>
                            <div class="tags-row">${badgesHtml}</div>
                        </div>
                        <i class="fa-solid fa-chevron-down" style="color:#bdc3c7"></i>
                    </div>
                    <div class="card-details">
                        ${d.description ? `<div class="detail-text" style="margin-bottom:10px; font-style:italic;">"${d.description}"</div>` : ''}
                        
                        <div class="filter-grid" style="margin-top:10px;">
                            <div><span class="detail-label">Instructor</span> ${d.instructor_name || 'Unknown'}</div>
                            <div><span class="detail-label">Credits</span> ${d.credits || '-'}</div>
                            <div><span class="detail-label">Format</span> ${d.delivery_format || '-'}</div>
                            <div><span class="detail-label">Frequency</span> ${d.term_frequency || '-'}</div>
                        </div>

                        ${skillsHtml ? `<div class="detail-block"><span class="detail-label">Tech Skills</span><div class="tags-row">${skillsHtml}</div></div>` : ''}
                        
                        ${d.textbooks && d.textbooks.length > 0 ? `<div class="detail-block"><span class="detail-label">Readings</span><ul style="margin:5px 0 0 15px; padding:0; font-size:12px; color:#555;">${d.textbooks.map(t=>`<li>${t}</li>`).join('')}</ul></div>` : ''}

                        ${prereqText}
                        ${pdfLink}
                    </div>
                `;

                resultsEl.appendChild(card);
            });

            // Fit map
            if (data.length > 0 && bounds.isValid()) {
                map.fitBounds(bounds, { padding: [50, 50], maxZoom: 10 });
            }
        }

        // --- INTERACTION ---
        window.toggleCard = function(header, lat, lon) {
            const card = header.parentElement;
            const wasActive = card.classList.contains('active');
            
            // Close others
            document.querySelectorAll('.card.active').forEach(c => c.classList.remove('active'));
            
            if (!wasActive) {
                card.classList.add('active');
                if (lat && lon) map.flyTo([lat, lon], 12);
            }
        };

        window.resetFilters = function() {
            document.querySelectorAll('select').forEach(s => s.value = 'all');
            document.getElementById('search-box').value = '';
            applyFilters();
        };

        // --- LISTENERS ---
        ['search-box', 'level-filter', 'domain-filter', 'assess-filter', 'software-filter', 'uni-filter', 'format-filter'].forEach(id => {
            document.getElementById(id).addEventListener(id === 'search-box' ? 'input' : 'change', applyFilters);
        });

        // --- START ---
        loadData();

    </script>
</body>
</html>